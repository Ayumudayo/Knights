.env
.env.*
!.env.example
!.env.default

# ==============================================================================
# IDE/Editor
# ==============================================================================
.vscode/
.vs/
.idea/
*.swp
*.swo
*~

# ==============================================================================
# Dependency Managers
# ==============================================================================
vcpkg_installed/
vcpkg/
*.vhdx
node_modules/

# ==============================================================================
# Test/Debug Files
# ==============================================================================
*.log
client.log
server.log
gateway.log
lb.log
test_*.py
verify_*.py

