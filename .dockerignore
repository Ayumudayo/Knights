# ==============================================================================
# Version Control
# ==============================================================================
.git
.gitignore
.gitattributes

# ==============================================================================
# Build Artifacts (Local Builds)
# ==============================================================================
build/
build-*/
out/
bin/
lib/
*.exe
*.dll
*.so
*.dylib
*.pdb
*.ilk
*.exp
*.lib
*.obj

# ==============================================================================
