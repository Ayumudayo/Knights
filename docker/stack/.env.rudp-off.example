# RUDP OFF invariance validation example (.env override for deploy_docker.ps1 -EnvFile)

# Direct gateway validation path
GATEWAY1_UDP_LISTEN=0.0.0.0:7000
GATEWAY2_UDP_LISTEN=
GATEWAY1_TCP_HOST_PORT=36100
GATEWAY1_UDP_HOST_PORT=7000

# Shared UDP bind guard config
GATEWAY_UDP_BIND_SECRET=replace-with-non-empty-secret
GATEWAY_UDP_BIND_TTL_MS=5000
GATEWAY_UDP_BIND_FAIL_WINDOW_MS=10000
GATEWAY_UDP_BIND_FAIL_LIMIT=5
GATEWAY_UDP_BIND_BLOCK_MS=60000

# RUDP disabled: attach attempt should fall back cleanly
GATEWAY_RUDP_ENABLE=0
GATEWAY_RUDP_CANARY_PERCENT=100
GATEWAY_RUDP_OPCODE_ALLOWLIST=0x0012
