{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "displayName": "Windows Base",
      "description": "Base configuration for Windows using VS2022 and vcpkg",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build-windows",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "toolchainFile": "${sourceDir}/cmake/knights_vcpkg_toolchain.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "displayName": "Linux Base",
      "description": "Base configuration for Linux using Ninja and vcpkg",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "toolchainFile": "${sourceDir}/cmake/knights_vcpkg_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "windows",
      "inherits": "windows-base",
      "displayName": "Windows (VS2022)",
      "description": "Windows configuration using Visual Studio 2022"
    },
    {
      "name": "linux",
      "inherits": "linux-base",
      "displayName": "Linux (Ninja)",
      "description": "Linux configuration using Ninja (Debug)"
    },
    {
      "name": "linux-release",
      "inherits": "linux-base",
      "displayName": "Linux Release (Ninja)",
      "description": "Linux configuration using Ninja (Release)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows",
      "configuration": "Debug",
      "displayName": "Windows Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows",
      "configuration": "RelWithDebInfo",
      "displayName": "Windows Release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux",
      "configuration": "Debug",
      "displayName": "Linux Debug"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "configuration": "Release",
      "displayName": "Linux Release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-test",
      "configurePreset": "windows",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-test",
      "configurePreset": "linux",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}